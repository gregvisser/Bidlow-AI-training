// AI Training Portal — production schema (Auth.js + domain)

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ——— Auth.js (Prisma adapter) ———

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(LEARNER)

  accounts Account[]
  sessions Session[]

  profile          Profile?
  enrollments      Enrollment[]
  lessonProgress   LessonProgress[]
  certificates     Certificate[]
  orders           Order[]
  subscriptions    Subscription[]
  invoices         Invoice[]
  providerCustomers PaymentProviderCustomer[]
  entitlements     Entitlement[]
  accessGrants     AccessGrant[] @relation("AccessGrantTarget")
  auditLogs        AuditLog[]    @relation("AuditActor")
  uploadedAssets   UploadedAsset[]
  paymentEvents    PaymentEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ——— Profile ———

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  headline    String?
  bio         String?
  company     String?
  timezone    String?  @default("UTC")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ——— Catalog ———

enum UserRole {
  SUPER_ADMIN
  ADMIN
  LEARNER
}

enum ContentProvider {
  AZURE
  HUGGING_FACE
  CURSOR
  AWS_INACTIVE
  GCP_INACTIVE
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model LearningPath {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String?  @db.Text
  durationWeeks   Int      @default(12)
  isFeatured      Boolean  @default(false)
  isPublic        Boolean  @default(true)
  heroImageUrl    String?
  thumbnailUrl    String?

  courses LearningPathCourse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id               String          @id @default(cuid())
  slug             String          @unique
  title            String
  subtitle         String?
  description      String?         @db.Text
  status           CourseStatus    @default(DRAFT)
  isPublic         Boolean         @default(false)
  isFeatured       Boolean         @default(false)
  provider         ContentProvider @default(AZURE)
  estimatedMinutes Int             @default(0)
  thumbnailUrl     String?
  heroImageUrl     String?
  /// subscription | one_time | included — CMS & billing labels
  pricingModel     String?         @default("included")

  modules          Module[]
  learningPaths    LearningPathCourse[]
  enrollments      Enrollment[]
  certificates     Certificate[]
  orderItems       OrderItem[]
  entitlements     Entitlement[]
  uploadedAssets   UploadedAsset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LearningPathCourse {
  id             String @id @default(cuid())
  learningPathId String
  courseId       String
  sortOrder      Int
  weekNumber     Int?

  learningPath LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([learningPathId, courseId])
  @@index([learningPathId, sortOrder])
}

model Module {
  id               String @id @default(cuid())
  courseId         String
  slug             String
  title            String
  description      String? @db.Text
  sortOrder        Int
  weekNumber       Int?
  estimatedMinutes Int    @default(0)
  archivedAt       DateTime?
  /// Weekly track label for learning-path UI (Azure / Hugging Face / Cursor)
  trackProvider    ContentProvider?

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@unique([courseId, slug])
  @@index([courseId, sortOrder])
}

model Lesson {
  id               String  @id @default(cuid())
  moduleId         String
  slug             String
  title            String
  content          String? @db.Text
  resourceUrl      String?
  externalLinks    Json?
  sortOrder        Int
  estimatedMinutes Int     @default(15)
  archivedAt       DateTime?

  module   Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@unique([moduleId, slug])
  @@index([moduleId, sortOrder])
}

// ——— Progress ———

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  status    String   @default("active")
  enrolledAt DateTime @default(now())
  lastActivityAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([userId, lastActivityAt])
}

model LessonProgress {
  id               String    @id @default(cuid())
  userId           String
  lessonId         String
  completedAt      DateTime?
  timeSpentSeconds Int       @default(0)
  notes            String?   @db.Text
  lastActivityAt   DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model Certificate {
  id         String    @id @default(cuid())
  userId     String
  courseId   String
  title      String
  unlockedAt DateTime?
  issuedAt   DateTime?
  pdfUrl     String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

// ——— Pricing & billing ———

enum PricingInterval {
  ONE_TIME
  MONTH
  YEAR
}

enum PlanKind {
  ONE_TIME
  SUBSCRIPTION
}

model PricingPlan {
  id                  String          @id @default(cuid())
  slug                String          @unique
  name                String
  description         String?         @db.Text
  kind                PlanKind
  interval            PricingInterval @default(ONE_TIME)
  amountCents         Int
  currency            String          @default("usd")
  stripePriceId       String?
  stripeProductId     String?
  paypalPlanId        String?
  isActive            Boolean         @default(true)
  features            Json?

  orderItems    OrderItem[]
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  MANUAL
}

model Order {
  id              String          @id @default(cuid())
  userId          String
  status          OrderStatus     @default(PENDING)
  provider        PaymentProvider
  providerRef     String?
  currency        String          @default("usd")
  totalCents      Int
  subtotalCents   Int
  taxCents        Int             @default(0)
  metadata        Json?
  /// Stripe Checkout Session id (cs_…)
  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String?
  /// PayPal Orders v2 order id
  paypalOrderId           String? @unique
  paypalCaptureId         String?

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]
  invoices Invoice[]
  entitlements Entitlement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([stripeCheckoutSessionId])
  @@index([paypalOrderId])
}

model OrderItem {
  id            String @id @default(cuid())
  orderId       String
  pricingPlanId String
  courseId      String?
  quantity      Int    @default(1)
  unitCents     Int

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pricingPlan PricingPlan @relation(fields: [pricingPlanId], references: [id])
  course      Course?     @relation(fields: [courseId], references: [id])
}

enum SubscriptionStatus {
  INCOMPLETE
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  TRIALING
  PAUSED
}

model Subscription {
  id                    String               @id @default(cuid())
  userId                String
  pricingPlanId         String
  status                SubscriptionStatus   @default(INCOMPLETE)
  provider              PaymentProvider
  stripeSubscriptionId  String?              @unique
  paypalSubscriptionId  String?              @unique
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean              @default(false)
  metadata              Json?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pricingPlan PricingPlan  @relation(fields: [pricingPlanId], references: [id])
  invoices    Invoice[]
  entitlements Entitlement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
}

enum InvoiceStatus {
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

model Invoice {
  id             String          @id @default(cuid())
  userId         String
  subscriptionId String?
  orderId        String?
  status         InvoiceStatus   @default(OPEN)
  provider       PaymentProvider
  providerRef    String?
  /// Stripe invoice id (in_xxx) when provider is STRIPE
  stripeInvoiceId String?        @unique
  amountCents    Int
  currency       String          @default("usd")
  paidAt         DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  order        Order?        @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
}

model PaymentProviderCustomer {
  id                 String          @id @default(cuid())
  userId             String          @unique
  stripeCustomerId   String?         @unique
  paypalPayerId      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentEvent {
  id              String          @id @default(cuid())
  provider        PaymentProvider
  externalEventId String
  eventType       String
  payload         Json?
  processedAt     DateTime        @default(now())
  userId          String?

  user User? @relation(fields: [userId], references: [id])

  @@unique([provider, externalEventId])
  @@index([processedAt])
}

enum EntitlementSource {
  ORDER
  SUBSCRIPTION
  MANUAL_GRANT
  PROMO
}

model Entitlement {
  id          String             @id @default(cuid())
  userId      String
  courseId    String?
  planId      String?
  source      EntitlementSource
  active      Boolean            @default(true)
  startsAt    DateTime           @default(now())
  endsAt      DateTime?
  orderId     String?
  subscriptionId String?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id])
  order          Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  subscription   Subscription?  @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, active])
  @@index([courseId])
  @@index([orderId])
  @@index([subscriptionId])
}

model AccessGrant {
  id        String   @id @default(cuid())
  grantedBy String
  targetId  String
  resource  String
  action    String
  expiresAt DateTime?

  grantedByUser User @relation("AccessGrantTarget", fields: [grantedBy], references: [id])
}

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  percentOff    Int?
  amountOffCents Int?
  maxRedemptions Int?
  redeemedCount Int       @default(0)
  expiresAt     DateTime?
  active        Boolean   @default(true)

  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([createdAt])
}

model UploadedAsset {
  id          String   @id @default(cuid())
  userId      String?
  courseId    String?
  kind        String
  blobName    String
  url         String
  contentType String?
  bytes       Int?

  user   User?   @relation(fields: [userId], references: [id])
  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([courseId, kind])
}
